# ─────────────────────────────────────────────────────────────────────────────
# Forge Scout — environment variables
#
# Copy this file to `.env.local` and fill in real values. `.env.local` is
# gitignored — never commit secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Server-side only.
DATABASE_URL="postgresql://user:password@host:5432/forge_scout"

# Set to "true" once your Postgres server has TLS enabled. Dokploy's default
# Postgres template image (postgres:17) ships with SSL **disabled**, so any
# SSL attempt errors with "The server does not support SSL connections."
# Don't put `sslmode=` in the URL — `pg` v8 maps it to `verify-full`, which
# hangs against self-signed certs.
DATABASE_SSL="false"

# ── OpenRouter (LLM) ────────────────────────────────────────────────────────
# Sign up at https://openrouter.ai/ and grab an API key (free tier available).
# Used for natural-language search. Can be empty while you're not working on
# the LLM features.
OPENROUTER_API_KEY=""
# OpenRouter's free pool is shared, so individual models often hit upstream
# rate-limits. GLM 4.5 Air has been the most consistently available + handles
# structured JSON output well. Browse https://openrouter.ai/models for
# alternatives (e.g. meta-llama/llama-3.3-70b-instruct:free,
# qwen/qwen3-next-80b-a3b-instruct:free).
OPENROUTER_MODEL="z-ai/glm-4.5-air:free"

# ── Forge data source ───────────────────────────────────────────────────────
# `scrape` reads HTML from forge component pages.
# `api`    calls the unofficial OutSystems Forge API.
FORGE_SOURCE="scrape"

# ── GitHub API ──────────────────────────────────────────────────────────────
# Optional. Without a token you get 60 req/hr (anonymous). A PAT raises the
# limit to 5000 req/hr. No special scopes needed for public repo metadata.
GITHUB_TOKEN=""

# ── Public ──────────────────────────────────────────────────────────────────
# Variables prefixed with VITE_ are exposed to the browser bundle. Never put
# secrets here.
VITE_APP_TITLE="Forge Scout"
